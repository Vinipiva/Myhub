---
import { realtorData as data } from "../lib/data";

type Metric = { value: string; label: string; color?: string };
type Section = { title: string; text: string };
---

<section id="realtor" class="relative py-8 sm:py-12 bg-gray-50 overflow-hidden transform-gpu">
  <div class="absolute inset-0 pointer-events-none transform-gpu">
    <img src="/images/cases/realtor-bg.svg" alt="" class="w-full h-full object-contain opacity-10" />
  </div>
  <div class="relative max-w-screen-2xl mx-auto px-2 sm:px-4 transform-gpu">
    <div class="grid grid-cols-1 md:grid-cols-7 gap-2 transform-gpu">

      <!-- Left col -->
      <div class="col col-span-1 md:col-span-2 relative transform-gpu">
        <div class="w-full">
          <h2 class="text-4xl sm:text-6xl text-gray-800">{data.company}</h2>
          <p class="text-2xl sm:text-4xl text-gray-600 mb-4 decorative-text">{data.role}</p>
          <div class="flex left mt-2">
            <span class="text-md font-bold text-white bg-gray-700 px-4 py-2 rounded-full">{data.period}</span>
            <span class="text-md font-bold text-white bg-gray-700 px-4 py-2 rounded-full ml-4">{data.type}</span>
          </div>
        </div>
        <div class="flex justify-center mb-4 bg-gray-800/90 p-4 sm:p-8 rounded-2xl shadow-lg mt-6 transform-gpu">
          <p class="text-base sm:text-xl text-white max-w-3xl mx-auto text-leading-relaxed text-left">{data.summary}</p>
        </div>
        <div class="flex flex-col items-center justify-center mt-6 transform-gpu">
          <div class="grid grid-cols-2 gap-6 transform-gpu">
            {data.metrics.map((m: Metric) => (
              <div class="bg-gray-800/90 p-8 rounded-2xl shadow-lg">
                <div class={`text-4xl md:text-5xl font-extrabold bg-gradient-to-b ${m.color ?? 'from-gray-300 to-gray-500'} text-transparent bg-clip-text`}>{m.value}</div>
                <p class="text-md md:text-lg text-white font-bold mt-2">{m.label}</p>
              </div>
            ))}
          </div>
        </div>
        <img src="/images/cases/family.png" alt="" class="w-40 sm:w-80 absolute -bottom-15 md:bottom-0 right-5 md:-right-8" />
      </div>

      <!-- Center col -->
      <div class="col col-span-1 md:col-span-3 transform-gpu">
        <img src="/images/cases/rdc.png" alt="Realtor.com mockup" class="w-full h-full object-contain" />
      </div>

      <!-- Right col - sections -->
      <div class="col col-span-1 md:col-span-2 transform-gpu">
        <div class="flex flex-col items-start space-y-6 text-left transform-gpu">
          {(data.sections ?? []).map((section: Section) => (
            <div class="bg-gray-800/90 p-8 rounded-2xl shadow-lg">
              <h3 class="text-xl font-bold text-white">{section.title}</h3>
              <p class="text-base text-gray-200 mt-2 leading-relaxed">{section.text}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
