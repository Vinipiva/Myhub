---
import { fanfestData as data } from "../lib/data";

type Section = { title: string; text: string };
type Metric = { value: string; label: string };
---

<div class="bg-gradient-to-b from-[#2566b3] to-[#f8f8f8] -translate-y-[1px] transform-gpu">
  <style>
    @keyframes blob-1-animation {
      0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); opacity: 0.7; filter: blur(40px); }
      33% { transform: translate(80px, -100px) scale(1.2) rotate(20deg); opacity: 0.5; filter: blur(50px); }
      66% { transform: translate(-40px, 60px) scale(0.9) rotate(-15deg); opacity: 0.6; filter: blur(35px); }
    }
    @keyframes blob-2-animation {
      0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); opacity: 0.6; filter: blur(50px); }
      33% { transform: translate(-100px, 120px) scale(1.1) rotate(-25deg); opacity: 0.4; filter: blur(60px); }
      66% { transform: translate(50px, -80px) scale(0.8) rotate(10deg); opacity: 0.55; filter: blur(45px); }
    }
    @keyframes blob-3-animation {
      0%, 100% { transform: translate(0px, 0px) scale(1) rotate(0deg); opacity: 0.7; filter: blur(30px); }
      33% { transform: translate(60px, 90px) scale(1.15) rotate(15deg); opacity: 0.5; filter: blur(40px); }
      66% { transform: translate(-90px, -50px) scale(0.95) rotate(-20deg); opacity: 0.65; filter: blur(25px); }
    }
    .animate-blob-1 { animation: blob-1-animation 5s infinite ease-in-out; }
    .animate-blob-2 { animation: blob-2-animation 8s infinite ease-in-out; animation-delay: 1s; }
    .animate-blob-3 { animation: blob-3-animation 12s infinite ease-in-out; animation-delay: 2s; }
    .perspective { perspective: 1000px; }
  </style>

  <div class="w-full bg-gradient-to-b from-slate-900 via-purple-900 to-slate-900 relative overflow-hidden py-20 md:py-64 text-white clip-inverted transform-gpu">
    <div class="absolute top-0 left-0 w-72 h-72 bg-purple-500/30 rounded-full animate-blob-1 opacity-70 transform-gpu"></div>
    <div class="absolute top-1/2 left-1/3 w-96 h-96 bg-pink-500/30 rounded-full animate-blob-2 opacity-60 transform-gpu"></div>
    <div class="absolute bottom-50 right-0 w-80 h-80 bg-indigo-500/30 rounded-full animate-blob-3 opacity-70 transform-gpu"></div>

    <div class="relative z-10 max-w-screen-2xl mx-auto transform-gpu">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">

        <!-- Left -->
        <div class="md:col-span-1 space-y-4 sm:space-y-6 bg-black/20 backdrop-blur-lg p-4 sm:p-8 rounded-2xl shadow-xl mt-4 sm:mt-6">
          <div class="flex items-center space-x-4 mb-6">
            <div>
              <h2 class="text-3xl md:text-6xl text-white">{data.company}</h2>
              <p class="text-4xl text-gray-200 mb-4 decorative-text">{data.role}</p>
              <div class="flex left">
                <span class="text-md font-bold text-white bg-black/20 px-4 py-2 rounded-full">{data.period}</span>
                <span class="text-md font-bold text-white bg-black/20 px-4 py-2 rounded-full ml-4">{data.type}</span>
              </div>
            </div>
          </div>
          {data.sections.map((section: Section) => (
            <div>
              <p class="text-lg font-bold text-purple-300">{section.title}:</p>
              <p class="text-lg text-gray-200 leading-relaxed">{section.text}</p>
            </div>
          ))}
        </div>

        <!-- Screens with hover effect -->
        <div class="mb-10 md:mb-0 md:col-span-2 flex items-center justify-center relative h-[320px] sm:h-[500px] md:h-[600px] group perspective transform-gpu">
          <div class="w-44 sm:w-48 md:w-72 lg:w-80 h-auto shadow-2xl translate-y-10 translate-x-10 transform transition-all duration-500 ease-out group-hover:-translate-x-5 group-hover:rotate-[-8deg] group-hover:scale-95 z-0 -rotate-4">
            <img src={data.screens[0].src} alt={data.screens[0].alt} class="h-full w-full" />
          </div>
          <div class="w-44 sm:w-48 md:w-80 lg:w-88 h-auto shadow-2xl transform transition-all duration-500 ease-out group-hover:scale-105 z-10">
            <img src={data.screens[1].src} alt={data.screens[1].alt} class="h-full w-full" />
          </div>
          <div class="w-44 sm:w-48 md:w-72 lg:w-80 h-auto shadow-2xl translate-y-10 -translate-x-10 transform transition-all duration-500 ease-out group-hover:translate-x-5 group-hover:rotate-[8deg] group-hover:scale-95 z-0 rotate-4">
            <img src={data.screens[2].src} alt={data.screens[2].alt} class="h-full w-full" />
          </div>
        </div>
      </div>

      <!-- Metrics -->
      <div class="flex flex-col sm:flex-row justify-between mt-4 sm:mt-6 gap-4 sm:gap-6 text-center transform-gpu">
        {data.metrics.map((m: Metric) => (
          <div class="bg-black/20 backdrop-blur-lg p-8 rounded-2xl shadow-lg flex-1">
            <div class="text-5xl font-extrabold bg-gradient-to-b from-purple-400 to-purple-600 text-transparent bg-clip-text">{m.value}</div>
            <p class="text-lg text-white font-bold mt-2">{m.label}</p>
          </div>
        ))}
      </div>

      <!-- Logos -->
      <div class="mt-8 sm:mt-12 transform-gpu">
        <div class="flex flex-wrap justify-center items-center gap-2 sm:gap-4">
          {data.logos.map((logo: string) => {
            const src = logo.includes("/")
              ? `/images/cases/${logo}`
              : `/images/cases/fanfest-logos/${logo}`;
            const name = logo.split("/").pop()!.replace(/\.(png|jpe?g)$/i, "").replace(/-/g, " ");
            return (
            <div class="h-10 w-10 sm:h-16 sm:w-16 rounded-full overflow-hidden flex-shrink-0">
              <img
                src={src}
                alt={name}
                class="h-full w-full object-cover"
              />
            </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</div>
