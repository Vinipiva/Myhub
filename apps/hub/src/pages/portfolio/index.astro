---
import { readdir, readFile } from "fs/promises";
import path from "path";
import PortfolioBuilder from "../../components/PortfolioBuilder.tsx";

export const prerender = false;

const CONTENT_BASE = path.resolve(process.cwd(), "../../apps/site/src/content");
const PRESENTATIONS_DIR = path.resolve(process.cwd(), "../../data/portfolio/presentations");

function parseFrontmatter(content: string): Record<string, string> {
  const match = content.match(/^---\n([\s\S]*?)\n---/);
  if (!match) return {};
  const result: Record<string, string> = {};
  for (const line of match[1].split("\n")) {
    const colonIdx = line.indexOf(":");
    if (colonIdx < 1) continue;
    const key = line.slice(0, colonIdx).trim();
    const val = line.slice(colonIdx + 1).trim().replace(/^["']|["']$/g, "");
    if (key && val) result[key] = val;
  }
  return result;
}

const projectFiles = await readdir(path.join(CONTENT_BASE, "projects")).catch(() => [] as string[]);
const caseFiles = await readdir(path.join(CONTENT_BASE, "cases")).catch(() => [] as string[]);

const projects = await Promise.all(
  projectFiles
    .filter((f) => f.endsWith(".md"))
    .map(async (f) => {
      const content = await readFile(path.join(CONTENT_BASE, "projects", f), "utf-8");
      const fm = parseFrontmatter(content);
      return { slug: f.replace(".md", ""), name: fm.company || f.replace(".md", "") };
    })
);

const cases = await Promise.all(
  caseFiles
    .filter((f) => f.endsWith(".md") && f !== ".gitkeep")
    .map(async (f) => {
      const content = await readFile(path.join(CONTENT_BASE, "cases", f), "utf-8");
      const fm = parseFrontmatter(content);
      return { slug: f.replace(".md", ""), name: fm.company || fm.title || f.replace(".md", "") };
    })
);

const availableProjects = cases.length > 0 ? cases : projects;
const portfolioUrl = import.meta.env.PUBLIC_PORTFOLIO_URL ?? "http://localhost:4323";

let presentations: any[] = [];
try {
  const files = await readdir(PRESENTATIONS_DIR);
  presentations = await Promise.all(
    files
      .filter((f) => f.endsWith(".json"))
      .map(async (f) => {
        const content = await readFile(path.join(PRESENTATIONS_DIR, f), "utf-8");
        return JSON.parse(content);
      })
  );
} catch {}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio Builder — Hub</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { font-family: system-ui, sans-serif; background: #f8fafc; min-height: 100vh; }
      header {
        background: #fff;
        border-bottom: 1px solid #e2e8f0;
        padding: 16px 32px;
        display: flex;
        align-items: center;
        gap: 24px;
      }
      header a { color: #6366f1; text-decoration: none; font-size: 14px; }
      header h1 { font-size: 16px; font-weight: 600; color: #1e293b; }
    </style>
  </head>
  <body>
    <header>
      <a href="/keystatic">← Hub</a>
      <h1>Portfolio</h1>
    </header>
    <PortfolioBuilder
      client:load
      initialPresentations={presentations}
      availableProjects={availableProjects}
      portfolioUrl={portfolioUrl}
    />
  </body>
</html>
