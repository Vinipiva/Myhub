---
import DeckLayout from "../../layouts/DeckLayout.astro";
import CaseDetail from "../../components/CaseDetail";
import { getDeckConfig, getContentProjects, getContentProjectBySlug, getCaseBySlug } from "../../lib/data";

export function getStaticPaths() {
  const projects = getContentProjects();
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getContentProjectBySlug(slug);
const caseStory = getCaseBySlug(slug) ?? null;
const config = getDeckConfig();
const allProjects = getContentProjects();

if (!project) {
  return Astro.redirect("/cases");
}

const idx = allProjects.findIndex((p) => p.slug === slug);
const prevSlug = idx > 0 ? allProjects[idx - 1].slug : null;
const nextSlug = idx < allProjects.length - 1 ? allProjects[idx + 1].slug : null;
---

<DeckLayout section="cases" caseSlug={slug}>
  <CaseDetail
    client:only="react"
    project={project}
    caseStory={caseStory}
    accent={config.theme.accent}
    foreground={config.theme.foreground}
    background={config.theme.background}
    prevSlug={prevSlug}
    nextSlug={nextSlug}
  />
</DeckLayout>
