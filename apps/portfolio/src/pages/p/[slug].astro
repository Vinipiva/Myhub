---
import PresentationLayout from "../../layouts/PresentationLayout.astro";
import PresentationDeck from "../../components/PresentationDeck";
import {
  getPresentations,
  getPresentation,
  getProfile,
  getExperience,
  getContentProjects,
} from "../../lib/data";

export function getStaticPaths() {
  const presentations = getPresentations();
  return presentations.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const presentation = getPresentation(slug);

if (!presentation) {
  return Astro.redirect("/");
}

const profile = getProfile();
const experience = getExperience();
const projects = getContentProjects();
---

<PresentationLayout title={`${presentation.name} — Portfolio`}>
  <PresentationDeck
    client:only="react"
    presentation={presentation}
    profile={profile!}
    experience={experience}
    projects={projects}
  />
</PresentationLayout>
