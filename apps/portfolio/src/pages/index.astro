---
import DeckLayout from "../layouts/DeckLayout.astro";
import { getDeckConfig, getContentProjects } from "../lib/data";

const config = getDeckConfig();
const { cover } = config;
const firstCase = getContentProjects()[0];
const firstCaseHref = firstCase ? `/cases/${firstCase.slug}` : "/cases";
---

<DeckLayout>
  <div class="cover">
    <div class="cover__content">
      <p class="cover__label">Interactive Portfolio</p>
      <h1 class="cover__headline">{cover.headline}</h1>
      <p class="cover__subheadline">{cover.subheadline}</p>
      <p class="cover__tagline">{cover.tagline}</p>
      {cover.availableFor && (
        <p class="cover__available">{cover.availableFor}</p>
      )}
    </div>

    <!-- Bottom nav — same pattern as CaseDetail -->
    <nav class="cover__nav">
      <span class="cover__site">viniciuspiva.com · 2026</span>

      <a href="/cases" class="cover__cases-link">
        View Cases
      </a>

      <div class="cover__arrows">
        <a href={firstCaseHref} class="cover__btn">→</a>
      </div>
    </nav>
  </div>
</DeckLayout>

<script>
  // Arrow key / space → go to first case
  window.addEventListener("keydown", (e) => {
    if (["ArrowRight", "ArrowDown", " "].includes(e.key)) {
      e.preventDefault();
      window.location.href = document.querySelector<HTMLAnchorElement>(".cover__btn")?.href ?? "/cases";
    }
  });
</script>

<style define:vars={{ accent: config.theme.accent, fg: config.theme.foreground }}>
  .cover {
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 120px;
    position: relative;
  }

  .cover__content {
    max-width: 1100px;
  }

  .cover__label {
    font-size: 13px;
    font-family: monospace;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 44px;
    opacity: 0.65;
  }

  .cover__headline {
    font-size: 120px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 28px;
  }

  .cover__subheadline {
    font-size: 32px;
    font-weight: 400;
    color: var(--fg);
    opacity: 0.7;
    margin-bottom: 20px;
  }

  .cover__tagline {
    font-size: 22px;
    color: var(--fg);
    opacity: 0.42;
    max-width: 720px;
    line-height: 1.55;
    margin-bottom: 44px;
  }

  .cover__available {
    font-size: 14px;
    font-family: monospace;
    color: var(--accent);
    opacity: 0.55;
    letter-spacing: 0.06em;
  }

  /* Bottom nav — mirrors CaseDetail's nav bar */
  .cover__nav {
    position: absolute;
    bottom: 44px;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 120px;
  }

  .cover__site {
    color: var(--fg);
    opacity: 0.28;
    font-size: 14px;
    font-family: monospace;
    letter-spacing: 0.04em;
  }

  .cover__cases-link {
    color: var(--fg);
    opacity: 0.32;
    text-decoration: none;
    font-size: 15px;
    font-family: monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }

  .cover__cases-link:hover {
    opacity: 0.7;
  }

  .cover__arrows {
    display: flex;
    gap: 10px;
  }

  .cover__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 6px;
    background: var(--accent);
    color: #09090b;
    font-size: 18px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .cover__btn:hover {
    opacity: 0.88;
  }
</style>
