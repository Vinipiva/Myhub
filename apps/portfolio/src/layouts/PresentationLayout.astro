---
interface Props {
  title?: string;
}
const { title = "Portfolio" } = Astro.props;
const w = 1920;
const h = 1080;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #09090b;
      }
      #deck {
        position: absolute;
        transform-origin: top left;
      }
    </style>
  </head>
  <body>
    <div
      id="deck"
      data-w={w}
      data-h={h}
      style={`width:${w}px;height:${h}px;`}
    >
      <slot />
    </div>

    <script>
      function scale() {
        const deck = document.getElementById("deck")!;
        const w = Number(deck.dataset.w);
        const h = Number(deck.dataset.h);
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const s = Math.min(vw / w, vh / h);
        deck.style.transform = `scale(${s})`;
        deck.style.left = `${(vw - w * s) / 2}px`;
        deck.style.top = `${(vh - h * s) / 2}px`;
      }
      scale();
      window.addEventListener("resize", scale);
    </script>
  </body>
</html>
