---
import DeckNav from "../components/DeckNav";
import { getDeckConfig, getContentProjects } from "../lib/data";

interface Props {
  section?: "cover" | "cases" | "process" | "timeline" | "education";
  caseSlug?: string;
}

const { section = "cover", caseSlug } = Astro.props;

const config = getDeckConfig();
const allProjects = getContentProjects();
const navCases = allProjects.map((p) => ({ slug: p.slug, company: p.company }));

const { w, h } = config.aspectRatio === "16:9"
  ? { w: 1920, h: 1080 }
  : { w: 1080, h: 1920 };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio — {config.cover.headline}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,300;0,400;0,500;0,700;0,900;1,400&family=Red+Hat+Text:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <!-- Flash-free sky theme: apply class before paint -->
    <script is:inline>
      if (typeof localStorage !== 'undefined' && localStorage.getItem('sky-theme') === 'light') {
        document.documentElement.classList.add('sky--light');
      }
    </script>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      /* Sky lives on <html> so toggling html.sky--light is instant & flash-free */
      html {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #06050f url('/images/sky-dark.png') center / cover no-repeat;
      }
      html.sky--light {
        background-image: url('/images/sky-light.png');
      }

      body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: transparent;
        font-family: 'Red Hat Text', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      #deck {
        position: absolute;
        transform-origin: top left;
        will-change: transform;
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
        background: transparent;
        font-family: 'Red Hat Text', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      button { font-family: inherit; }
      a { font-family: inherit; }

      /* Secondary pages: floating glass card — sky breathes all around it */
      .page-glass {
        position: absolute;
        top: 70px;       /* 56px nav + 14px breathing gap */
        left: 40px;
        right: 40px;
        bottom: 36px;
        backdrop-filter: blur(40px) saturate(180%) brightness(1.02);
        -webkit-backdrop-filter: blur(40px) saturate(180%) brightness(1.02);
        background: rgba(255, 255, 255, 0.88);
        border: 1px solid rgba(255, 255, 255, 0.55);
        border-radius: 18px;
        box-shadow:
          0 24px 80px rgba(0, 0, 0, 0.10),
          0 4px 16px rgba(0, 0, 0, 0.06),
          inset 0 1px 0 rgba(255, 255, 255, 0.80);
        overflow: hidden;
        z-index: 1;
      }
      /* Light sky — slightly more opaque, tinted shadow picks up sky color */
      html.sky--light .page-glass {
        background: rgba(255, 255, 255, 0.90);
        backdrop-filter: blur(40px) saturate(160%) brightness(1.01);
        -webkit-backdrop-filter: blur(40px) saturate(160%) brightness(1.01);
        border: 1px solid rgba(255, 255, 255, 0.70);
        box-shadow:
          0 24px 80px rgba(120, 100, 200, 0.12),
          0 4px 16px rgba(0, 0, 0, 0.04),
          inset 0 1px 0 rgba(255, 255, 255, 0.90);
      }
    </style>
  </head>
  <body>
    <div
      id="deck"
      data-w={w}
      data-h={h}
      style={`width:${w}px;height:${h}px;color:${config.theme.foreground};position:relative;overflow:hidden;`}
    >
      <DeckNav
        client:load
        section={section}
        caseSlug={caseSlug}
        cases={navCases}
        accent={config.theme.accent}
        fg={config.theme.foreground}
      />
      {section !== "cover" ? (
        <div class="page-glass"><slot /></div>
      ) : (
        <slot />
      )}
    </div>

    <script>
      function scale() {
        const deck = document.getElementById("deck")!;
        const w = Number(deck.dataset.w);
        const h = Number(deck.dataset.h);
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const s = Math.min(vw / w, vh / h);
        deck.style.transform = `scale(${s})`;
        deck.style.left = `${(vw - w * s) / 2}px`;
        deck.style.top  = `${(vh - h * s) / 2}px`;
      }
      scale();
      window.addEventListener("resize", scale);
    </script>
  </body>
</html>
