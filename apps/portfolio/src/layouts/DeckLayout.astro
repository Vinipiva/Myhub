---
import { getDeckConfig } from "../lib/data";

const config = getDeckConfig();
const { w, h } = config.aspectRatio === "16:9"
  ? { w: 1920, h: 1080 }
  : { w: 1080, h: 1920 };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio — {config.cover.headline}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: var(--bg);
      }
      #deck {
        position: absolute;
        transform-origin: top left;
      }
    </style>
    <style define:vars={{ bg: config.theme.background, fg: config.theme.foreground, accent: config.theme.accent }}>
      :root {
        --bg: var(--bg);
        --fg: var(--fg);
        --accent: var(--accent);
      }
    </style>
  </head>
  <body>
    <div
      id="deck"
      data-w={w}
      data-h={h}
      style={`width:${w}px;height:${h}px;background:${config.theme.background};color:${config.theme.foreground};`}
    >
      <slot />
    </div>

    <script>
      function scale() {
        const deck = document.getElementById("deck")!;
        const w = Number(deck.dataset.w);
        const h = Number(deck.dataset.h);
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const s = Math.min(vw / w, vh / h);
        deck.style.transform = `scale(${s})`;
        deck.style.left = `${(vw - w * s) / 2}px`;
        deck.style.top = `${(vh - h * s) / 2}px`;
      }
      scale();
      window.addEventListener("resize", scale);
    </script>
  </body>
</html>
