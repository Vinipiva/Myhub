---
import DeckNav from "../components/DeckNav";
import { getDeckConfig, getContentProjects } from "../lib/data";

interface Props {
  section?: "cover" | "cases" | "process" | "timeline" | "education";
  caseSlug?: string;
}

const { section = "cover", caseSlug } = Astro.props;

const config = getDeckConfig();
const allProjects = getContentProjects();
const navCases = allProjects.map((p) => ({ slug: p.slug, company: p.company }));

const { w, h } = config.aspectRatio === "16:9"
  ? { w: 1920, h: 1080 }
  : { w: 1080, h: 1920 };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portfolio — {config.cover.headline}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:ital,wght@0,300;0,400;0,500;0,700;0,900;1,400&family=Red+Hat+Text:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        width: 100%;
        height: 100%;
        overflow: hidden;
        background: #d8dce6;
        font-family: 'Red Hat Text', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      #deck {
        position: absolute;
        transform-origin: top left;
        will-change: transform;
        backface-visibility: hidden;
        -webkit-font-smoothing: antialiased;
        background: #ffffff;
        font-family: 'Red Hat Text', -apple-system, BlinkMacSystemFont, sans-serif;
      }

      button { font-family: inherit; }
      a { font-family: inherit; }
    </style>
  </head>
  <body>
    <div
      id="deck"
      data-w={w}
      data-h={h}
      style={`width:${w}px;height:${h}px;color:${config.theme.foreground};position:relative;overflow:hidden;`}
    >
      <DeckNav
        client:load
        section={section}
        caseSlug={caseSlug}
        cases={navCases}
        accent={config.theme.accent}
        fg={config.theme.foreground}
      />
      <slot />
    </div>

    <script>
      function scale() {
        const deck = document.getElementById("deck")!;
        const w = Number(deck.dataset.w);
        const h = Number(deck.dataset.h);
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const s = Math.min(vw / w, vh / h);
        deck.style.transform = `scale(${s})`;
        deck.style.left = `${(vw - w * s) / 2}px`;
        deck.style.top  = `${(vh - h * s) / 2}px`;
      }
      scale();
      window.addEventListener("resize", scale);
    </script>
  </body>
</html>
